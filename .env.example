# ─────────────────────────────────────────────────────────────────────────────
# VoxHorizon website — environment variables
# Copy to .env.local and fill in. Start with LEAD_API_MODE=mock for frontend dev.
# Never commit .env.local. NEXT_PUBLIC_* are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Canonical site URL (metadata, sitemap, OG, canonical links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Lead pipeline mode: "mock" returns a canned success (no DB/email/CRM calls);
# "live" performs the real flow and requires the Supabase vars below.
LEAD_API_MODE=mock

# ── Supabase (server-only; service role bypasses RLS — never expose) ──────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Transactional email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=
# Where new-lead alerts are sent (comma-separated allowed)
LEAD_NOTIFY_TO=diogosilvaenterprise@gmail.com
# Verified sender; domain must be verified in Resend
LEAD_NOTIFY_FROM=leads@voxhorizon.com

# ── GoHighLevel sync (inbound webhook to your CRM/calendar workflow) ──────────
GHL_WEBHOOK_URL=

# ── Booking embed shown after qualification (GHL calendar or Calendly URL) ────
NEXT_PUBLIC_BOOKING_URL=

# ── Optional: spam protection (hCaptcha) ─────────────────────────────────────
HCAPTCHA_SECRET=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# ── Optional: durable rate limiting across runtime instances (Upstash Redis) ─
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional: privacy-friendly analytics (Plausible) ─────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
